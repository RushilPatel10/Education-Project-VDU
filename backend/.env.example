# Copy this file to .env and fill in real values (no spaces around =).

PORT=5000

# MongoDB Atlas: Database > Connect > Drivers → copy SRV string.
# Must include database name and options, e.g.:
# mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/education_db?retryWrites=true&w=majority
# Atlas: Network Access → allow your IP or 0.0.0.0/0 for development.
MONGO_URI=

# Any long random string for JWT signing (keep secret).
JWT_SECRET=

# Optional: extra allowed frontend origins for CORS (comma-separated).
# CLIENT_ORIGIN=
